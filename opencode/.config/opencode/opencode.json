{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "bash": {
      "git push *": "deny",
      "rm *": "ask",
      "git reset *": "deny",
      "git commit *": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "compaction": {
    "auto": false
  },
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
