{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "backlight",
        "backlight/slider",
        "pulseaudio",
        "pulseaudio/slider",
        "custom/mic"
    ],
    "modules-right": [
        "temperature",
        "cpu",
        "memory",
        "network",
        "custom/clock",
        "battery",
        "custom/rotation-lock",
        "custom/virtkbd"
    ],
    "sway/workspaces": {
        "format": "{name}",
        "format-alt": "{name}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": " muted",
        "tooltip": true,
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                "",
                ""
            ]
        }
    },
    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "{icon} {capacity}%",
        "format-plugged": "{icon} {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "tooltip": true,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ]
    },
    "network": {
        "format-wifi": "{icon}  {essid}",
        "format-ethernet": "{icon}",
        "format-disconnected": "",
        "tooltip": true,
        "format-icons": {
            "wifi": [
                "",
                "",
                "",
                ""
            ],
            "ethernet": "",
            "disconnected": ""
        },
        "max-length": 20
    },
    "clock": {
        "format": "{:%b %d %H:%M}",
        "tooltip": true,
        "tooltip-format": "{:%a %b %d %Y  %H:%M:%S}"
    },
    "temperature": {
        "format": "{temperatureC}°C",
        "format-critical": "{temperatureC}°C",
        "tooltip": true,
        "critical-threshold": 80
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}  {percent}%",
        "format-icons": [
            ""
        ],
        "tooltip": true
    },
    "backlight/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },
    "cpu": {
        "format": " {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": " {percentage}%",
        "tooltip": true
    },
    "transition-duration": 200,
    "custom/virtkbd": {
        "format": "",
        "tooltip": "Toggle virtual keyboard",
        "on-click": "~/.local/bin/toggle-virtkbd"
    },
    "custom/rotation-lock": {
        "tooltip": "Toggle rotation lock",
        "on-click": "~/.local/bin/toggle-rotation-lock",
        "exec": "~/.local/bin/get-rotation-lock-status",
        "interval": 5
    },
    "custom/mic": {
        "format": "{}",
        "tooltip": "Toggle microphone",
        "on-click": "~/.local/bin/toggle-mic",
        "exec": "~/.local/bin/get-mic-status",
        "interval": 5
    },
    "custom/clock": {
        "format": "{}",
        "exec": "date '+%b %d %H:%M'",
        "interval": 10
    }
}
